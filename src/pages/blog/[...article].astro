---
/**
 * Article Detail Page
 * 
 * Two-column layout: left sidebar (metadata + collapsible TOC) + right content area.
 * Inspired by modern design publications with clean typography and strong hierarchy.
 * 
 * Route: /blog/[slug]
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import StructuredData from '../../components/StructuredData.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import BackLink from '../../components/BackLink.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const articles = await getCollection('writing', ({ data }) => data.draft === false);
  return articles.map((article) => ({
    params: { article: article.id },
  }));
}

const { article: slug } = Astro.params;
const article = await getEntry('writing', slug!);

if (!article) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(article);

const { title, description, publishDate, updatedDate, tags, category } = article.data;
const readingTime = getReadingTime(article.body || '');

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout>
  <SEO
    slot="head"
    title={`${title} - Writing`}
    description={description}
    type="article"
    publishDate={publishDate}
    updatedDate={updatedDate}
  />

  <StructuredData
    type="Article"
    data={{
      title,
      description,
      publishDate,
      updatedDate,
      tags,
      url: Astro.url.href,
    }}
  />

  <div class="article-page">
    <!-- LEFT SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <div class="sidebar-meta">
          <div class="meta-block">
            <span class="meta-label">date</span>
            <time class="meta-value" datetime={publishDate.toISOString()}>
              {formatDate(publishDate)}
            </time>
          </div>
          {category && (
            <div class="meta-block">
              <span class="meta-label">category</span>
              <span class="meta-value">{category}</span>
            </div>
          )}
          {tags && tags.length > 0 && (
            <div class="meta-block">
              <span class="meta-label">tags</span>
              <div class="meta-tags">
                {tags.map((tag) => (
                  <span class="meta-tag">{tag}</span>
                ))}
              </div>
            </div>
          )}
          <!-- Collapsible TOC -->
          {tocHeadings.length >= 2 && (
            <nav class="toc-nav" aria-label="文章目录">
              <button class="toc-toggle" id="toc-toggle">
                <span class="toc-toggle-label">chapters</span>
                <span class="toc-toggle-icon" id="toc-icon">&#9660;</span>
              </button>
              <ul class="toc-list" id="toc-list">
                {tocHeadings.map((heading) => (
                  <li class={`toc-item toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`} class="toc-link">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}
        </div>
      </div>
    </aside>

    <!-- RIGHT CONTENT -->
    <main class="content-area">
      <header class="content-header">
        <h1 class="content-title">{title}</h1>
        <p class="content-desc">{description}</p>
      </header>
      <article class="article-content">
        <Content />
      </article>

      <div class="article-footer">
        <BackLink href="/blog" text="返回博客" />
      </div>
    </main>
  </div>

  <ScrollToTop />

  <script>
    const tocToggle = document.getElementById('toc-toggle');
    const tocList = document.getElementById('toc-list');
    const tocIcon = document.getElementById('toc-icon');
    if (tocToggle && tocList && tocIcon) {
      tocToggle.addEventListener('click', () => {
        const isOpen = tocList.style.display !== 'none';
        tocList.style.display = isOpen ? 'none' : 'block';
        tocIcon.textContent = isOpen ? '\u25B6' : '\u25BC';
      });
    }

    // Fix TOC anchor links (View Transitions intercepts hash navigation)
    document.querySelectorAll('.toc-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          const target = document.getElementById(href.slice(1));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.replaceState(null, '', href);
          }
        }
      });
    });

    // Active TOC link on scroll
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length > 0) {
      const sections = [...tocLinks].map(link => {
        const id = link.getAttribute('href')?.slice(1);
        return id ? document.getElementById(id) : null;
      }).filter(Boolean);

      function updateActive() {
        let current = '';
        for (const section of sections) {
          if (section && section.getBoundingClientRect().top <= 120) {
            current = section.id;
          }
        }
        tocLinks.forEach(link => {
          const href = link.getAttribute('href')?.slice(1);
          link.classList.toggle('is-active', href === current);
        });
      }

      window.addEventListener('scroll', updateActive, { passive: true });
      updateActive();
    }
  </script>

  <style>
    /* ============================================
       PAGE LAYOUT
       ============================================ */
    .article-page {
      display: flex;
      max-width: 1300px;
      margin: 0 auto;
      padding: 2rem 1.5rem 6rem;
      gap: 3.5rem;
      min-height: calc(100vh - 4rem);
    }

    /* ============================================
       LEFT SIDEBAR
       ============================================ */
    .sidebar {
      width: 280px;
      flex-shrink: 0;
    }

    .sidebar-inner {
      position: sticky;
      top: 5rem;
    }

    .sidebar-meta {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .meta-block {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .meta-label {
      font-family: 'Unbounded', sans-serif;
      font-size: 1.125rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .meta-value {
      font-size: 1rem;
      font-weight: 400;
      color: var(--color-text-secondary);
      line-height: 1.5;
    }

    .meta-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .meta-tag {
      font-size: 0.875rem;
      padding: 0.25rem 0.75rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-text-secondary);
    }

    /* ============================================
       COLLAPSIBLE TOC
       ============================================ */
    .toc-nav {
      padding-top: 0.5rem;
    }

    .toc-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0;
      margin-bottom: 0.75rem;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--color-text);
      font-family: 'Unbounded', sans-serif;
      font-size: 1.125rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .toc-toggle:hover {
      color: var(--color-accent);
    }

    .toc-toggle-icon {
      font-size: 0.75rem;
      transition: transform 0.2s ease;
      color: var(--color-text-muted);
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-item {
      margin-bottom: 0.25rem;
      line-height: 1.5;
    }

    .toc-depth-3 {
      padding-left: 0.875rem;
    }

    .toc-link {
      display: block;
      font-size: 0.9375rem;
      color: var(--color-text-muted);
      text-decoration: none;
      padding: 0.375rem 0 0.375rem 0.875rem;
      border-left: 2px solid var(--color-border);
      transition: color 0.2s ease, border-color 0.2s ease;
    }

    .toc-link:hover {
      color: var(--color-text);
    }

    .toc-link.is-active {
      color: var(--color-accent);
      border-left-color: var(--color-accent);
    }

    /* ============================================
       RIGHT CONTENT AREA
       ============================================ */
    .content-area {
      flex: 1;
      min-width: 0;
    }

    .content-header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .content-title {
      font-family: 'Unbounded', sans-serif;
      font-size: 3rem;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--color-text);
      margin-bottom: 1rem;
    }

    .content-desc {
      font-size: 1.125rem;
      line-height: 1.6;
      color: var(--color-text-muted);
      max-width: 600px;
    }

    .article-content {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--color-text);
    }

    .article-content :global(h2) {
      font-size: 1.75rem;
      margin-top: 3rem;
      margin-bottom: 1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      line-height: 1.3;
      color: var(--color-text);
      scroll-margin-top: 5rem;
    }

    .article-content :global(h3) {
      font-size: 1.375rem;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      line-height: 1.4;
      color: var(--color-text);
      scroll-margin-top: 5rem;
    }

    .article-content :global(h4) {
      font-size: 1.125rem;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      font-weight: 600;
      line-height: 1.5;
      color: var(--color-text);
    }

    .article-content :global(p) {
      margin-bottom: 1.5rem;
      color: var(--color-text-secondary);
    }

    .article-content :global(ul),
    .article-content :global(ol) {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
      color: var(--color-text-secondary);
    }

    .article-content :global(li) {
      margin-bottom: 0.5rem;
      line-height: 1.7;
    }

    .article-content :global(blockquote) {
      margin: 2rem 0;
      padding: 1rem 1.5rem;
      border-left: 4px solid var(--color-accent);
      background: var(--color-bg-secondary);
      font-style: italic;
      color: var(--color-text-secondary);
    }

    .article-content :global(code) {
      font-family: ui-monospace, 'JetBrains Mono', 'Cascadia Code', Menlo, Consolas, 'Courier New', monospace;
      font-size: 0.9em;
      background: var(--color-bg-secondary);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      color: var(--color-text);
    }

    .article-content :global(pre) {
      margin: 2rem 0;
      padding: 1.5rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow-x: auto;
    }

    .article-content :global(pre code) {
      background: none;
      padding: 0;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    .article-content :global(a) {
      color: var(--color-accent);
      text-decoration: underline;
    }

    .article-content :global(a:hover) {
      color: var(--color-accent-hover);
    }

    .article-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 2rem 0;
    }

    .article-content :global(hr) {
      margin: 3rem 0;
      border: none;
      border-top: 1px solid var(--color-border);
    }

    .article-content :global(strong) {
      color: var(--color-text);
      font-weight: 600;
    }

    .article-footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--color-border);
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 900px) {
      .article-page {
        flex-direction: column;
        gap: 2rem;
        padding: 1.5rem 1rem 4rem;
      }

      .sidebar {
        width: 100%;
      }

      .sidebar-inner {
        position: static;
      }

      .content-title {
        font-size: 2.25rem;
      }

      .article-content {
        font-size: 1rem;
      }

      .article-content :global(h2) {
        font-size: 1.5rem;
      }

      .article-content :global(h3) {
        font-size: 1.25rem;
      }
    }

    @media (max-width: 600px) {
      .content-title {
        font-size: 1.75rem;
      }

      .meta-label {
        font-size: 1rem;
      }

      .article-content :global(pre) {
        padding: 1rem;
      }
    }
  </style>
</BaseLayout>
