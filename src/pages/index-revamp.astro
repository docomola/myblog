    /* --- Brand Marquee (pure CSS infinite scroll) --- */
    .brand-marquee {
      --bm-gap: 60px;
      --bm-height: 40px;
      --bm-speed: 40s;
      overflow: hidden;
      height: 100px;
      display: flex;
      align-items: center;
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        #000 12%,
        #000 88%,
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        #000 12%,
        #000 88%,
        transparent 100%
      );
    }

    .brand-marquee__track {
      display: flex;
      align-items: center;
      gap: var(--bm-gap);
      width: max-content;
      animation: brand-scroll var(--bm-speed) linear infinite;
    }

    .brand-marquee:hover .brand-marquee__track {
      animation-play-state: paused;
    }

    @keyframes brand-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .brand-marquee__item {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      gap: var(--bm-gap);
    }

    .brand-marquee__item img {
      height: var(--bm-height);
      width: auto;
      display: block;
      object-fit: contain;
      filter: invert(1);
      opacity: 0.5;
      transition: opacity 0.3s ease;
    }

    .brand-marquee:hover .brand-marquee__item img {
      opacity: 0.75;
    }

    @media (max-width: 640px) {
      .brand-marquee {
        --bm-gap: 36px;
        --bm-height: 30px;
        --bm-speed: 28s;
        height: 70px;
      }
    }

