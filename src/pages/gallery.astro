---
/**
 * Gallery Page - 画廊 (Portfolio Gallery Style)
 * Reads album data from src/content/gallery/ Markdown files.
 * Route: /gallery
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';

// Fetch all non-draft albums, sorted by order
const allAlbums = await getCollection('gallery', ({ data }) => !data.draft);
const galleryItems = allAlbums.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// Extract unique categories for filter tabs
const categories = ['全部', ...new Set(galleryItems.map(item => item.data.category))];
---

<BaseLayout>
  <SEO
    slot="head"
    title="画廊"
    description="作品集与项目展示。"
    type="website"
  />

  <div class="gallery-page">
    <!-- Hero Header -->
    <div class="gallery-hero">
      <div class="gallery-hero-top">
        <span class="gallery-hero-label">Portfolio</span>
        <span class="gallery-hero-status">
          <span class="status-dot"></span>
          Available for work
        </span>
      </div>
      <h1 class="gallery-hero-title">Selected Works.</h1>
      <p class="gallery-hero-count">Showing {galleryItems.length} projects</p>
    </div>

    <!-- Filter Tabs -->
    <nav class="filter-tabs">
      {categories.map((cat, i) => (
        <button
          class:list={['filter-tab', { active: i === 0 }]}
          data-category={cat === '全部' ? 'all' : cat}
        >
          {cat}
        </button>
      ))}
    </nav>

    <!-- Project Grid -->
    <div class="project-grid">
      {galleryItems.map((item, idx) => (
        <a href={'/gallery/' + item.id} class="project-card" data-category={item.data.category}>
          {item.data.cover ? (
            <div class="project-card-bg" style={'background-image: url(' + item.data.cover + '); background-size: cover; background-position: center;'}>
            </div>
          ) : (
            <div class="project-card-bg" style={'background: linear-gradient(' + (135 + (idx + 1) * 40) + 'deg, hsl(' + ((idx + 1) * 55 + 200) + ', 55%, 45%), hsl(' + ((idx + 1) * 55 + 280) + ', 50%, 30%))'}>
              <span class="project-card-letter">{item.data.letter}</span>
            </div>
          )}
          <div class="project-card-overlay"></div>
          <span class="project-card-year">{item.data.year}</span>
          <div class="project-card-bottom">
            <h3 class="project-card-title">{item.data.title}</h3>
            <span class="project-card-tag">{item.data.category}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Filter Script (supports ?category=xxx URL param) -->
  <script>
    const tabs = document.querySelectorAll('.filter-tab');
    const cards = document.querySelectorAll('.project-card');

    function filterBy(category: string) {
      tabs.forEach(t => t.classList.remove('active'));
      const matchTab = [...tabs].find(t => t.getAttribute('data-category') === category) || tabs[0];
      matchTab.classList.add('active');

      cards.forEach(card => {
        const el = card as HTMLElement;
        const cardCategory = el.getAttribute('data-category');
        if (category === 'all' || cardCategory === category) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterBy(tab.getAttribute('data-category') ?? 'all');
      });
    });

    // Auto-filter from URL ?category=xxx
    const params = new URLSearchParams(window.location.search);
    const urlCategory = params.get('category');
    if (urlCategory) {
      filterBy(urlCategory);
    }
  </script>

  <style>
    .gallery-page {
      max-width: 1400px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    /* ============================================
       HERO HEADER
       ============================================ */
    .gallery-hero {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .gallery-hero-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .gallery-hero-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-text-muted);
    }

    .gallery-hero-status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22c55e;
      display: inline-block;
    }

    .gallery-hero-title {
      font-family: 'Unbounded', sans-serif;
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--color-text);
      margin-bottom: 0.5rem;
    }

    .gallery-hero-count {
      font-size: 0.875rem;
      color: var(--color-text-muted);
      font-weight: 400;
    }

    /* ============================================
       FILTER TABS
       ============================================ */
    .filter-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .filter-tab {
      padding: 0.5rem 1.25rem;
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--color-text-muted);
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 2rem;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;
    }

    .filter-tab:hover {
      color: var(--color-text);
      border-color: var(--color-text-muted);
    }

    .filter-tab.active {
      background: var(--color-text);
      color: var(--color-bg);
      border-color: var(--color-text);
    }

    /* ============================================
       PROJECT GRID
       ============================================ */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .project-card {
      display: block;
      position: relative;
      aspect-ratio: 16 / 9;
      border-radius: 1rem;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      cursor: pointer;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s ease;
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    /* Card Background */
    .project-card-bg {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .project-card:hover .project-card-bg {
      transform: scale(1.06);
    }

    .project-card-letter {
      font-family: 'Unbounded', sans-serif;
      font-size: 10rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.18);
      line-height: 1;
      user-select: none;
    }

    /* Gradient overlay at bottom for text readability */
    .project-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.7) 0%,
        rgba(0, 0, 0, 0.25) 35%,
        rgba(0, 0, 0, 0) 60%
      );
      z-index: 1;
    }

    /* Year in top-right */
    .project-card-year {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      font-size: 0.75rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.7);
      z-index: 2;
      letter-spacing: 0.04em;
    }

    /* Bottom info */
    .project-card-bottom {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem;
      z-index: 2;
    }

    .project-card-title {
      font-size: 1.375rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.01em;
      line-height: 1.3;
      margin-bottom: 0.75rem;
      text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
    }

    .project-card-tag {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.15);
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 1024px) {
      .project-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .project-card-letter {
        font-size: 7rem;
      }
    }

    @media (max-width: 768px) {
      .gallery-page {
        padding: 2rem 1rem 4rem;
      }

      .gallery-hero-title {
        font-size: 2.5rem;
      }

      .project-card-letter {
        font-size: 5rem;
      }

      .project-card-title {
        font-size: 1.125rem;
      }

      .project-card-bottom {
        padding: 1.25rem;
      }

      .filter-tabs {
        gap: 0.375rem;
      }
    }

    @media (max-width: 480px) {
      .gallery-hero-title {
        font-size: 2rem;
      }

      .project-grid {
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }

      .project-card-letter {
        font-size: 6rem;
      }

      .gallery-hero-top {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
      }
    }
  </style>
</BaseLayout>
