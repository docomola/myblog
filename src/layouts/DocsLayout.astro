---
/**
 * DocsLayout - Three-column documentation layout
 * Left: DocsSidebar | Center: Content | Right: DocsTOC
 */
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsTOC from '../components/DocsTOC.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';

interface DocLink {
  label: string;
  href: string;
}

interface DocSection {
  folder: string;
  links: DocLink[];
}

interface TOCItem {
  text: string;
  slug: string;
  children?: TOCItem[];
}

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  sidebarSections: DocSection[];
  currentPath: string;
  toc?: TOCItem[];
  breadcrumbs?: Crumb[];
  prevPage?: { label: string; href: string } | null;
  nextPage?: { label: string; href: string } | null;
}

const {
  title,
  description = '',
  sidebarSections,
  currentPath,
  toc = [],
  breadcrumbs = [{ label: title }],
  prevPage,
  nextPage,
} = Astro.props;

const allDocs = await getCollection('docs');
const totalDocs = allDocs.length;
const totalSections = sidebarSections.length;
---

<BaseLayout>
  <SEO
    slot="head"
    title={`${title} - 技术文档`}
    description={description}
    type="website"
  />

  <div class="docs-page">
    <div class="docs-layout">
      <!-- Left Sidebar -->
      <DocsSidebar sections={sidebarSections} currentPath={currentPath} />

      <!-- Main Content Area -->
      <main class="docs-main">
        <!-- Hero Header (inside right column, left-aligned) -->
        <header class="docs-hero">
          <div class="docs-hero-top">
            <span class="docs-hero-label">Documentation</span>
            <span class="docs-hero-status">
              <span class="status-dot"></span>
              Available for work
            </span>
          </div>
          <h1 class="docs-hero-title"><a href="/docs" class="docs-hero-link">Docs.</a></h1>
          <p class="docs-hero-count">{totalDocs} articles · {totalSections} sections</p>
        </header>

        <Breadcrumb items={breadcrumbs} />

        <article class="docs-content">
          <slot />
        </article>

      <!-- Prev / Next Navigation -->
      {(prevPage || nextPage) && (
        <nav class="docs-pagination">
          {prevPage ? (
            <a href={prevPage.href} class="pagination-link pagination-prev">
              <span class="pagination-label">← 上一页</span>
              <span class="pagination-title">{prevPage.label}</span>
            </a>
          ) : (
            <div />
          )}
          {nextPage ? (
            <a href={nextPage.href} class="pagination-link pagination-next">
              <span class="pagination-label">下一页 →</span>
              <span class="pagination-title">{nextPage.label}</span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      )}
    </main>

    <!-- Right TOC -->
    {toc.length > 0 && <DocsTOC items={toc} />}
    </div>
  </div>

  <style is:global>
    :root {
      --docs-max-width: 800px;
    }
  </style>

  <style>
    .docs-page {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem 3rem 0 10rem;
    }

    /* Hero Header */
    .docs-hero {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }
    .docs-hero-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }
    .docs-hero-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-text-muted);
    }
    .docs-hero-status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
    }
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22c55e;
      display: inline-block;
    }
    .docs-hero-title {
      font-family: 'Unbounded', sans-serif;
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--color-text);
      margin-bottom: 0.5rem;
    }
    .docs-hero-link {
      color: inherit;
      text-decoration: none;
    }
    .docs-hero-link:hover {
      opacity: 0.8;
    }
    .docs-hero-count {
      font-size: 0.875rem;
      color: var(--color-text-muted);
      font-weight: 400;
    }

    .docs-layout {
      display: flex;
      min-height: calc(100vh - 250px);
    }

    .docs-main {
      flex: 1;
      min-width: 0;
      padding: 2rem 2.5rem 4rem;
      max-width: calc(100% - 480px);
    }

    .docs-content {
      max-width: var(--docs-max-width);
    }

    /* Typography */
    .docs-content :global(h1) {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .docs-content :global(h2) {
      font-size: 1.375rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .docs-content :global(h3) {
      font-size: 1.125rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    .docs-content :global(p) {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: var(--color-text-secondary);
      margin-bottom: 1.25rem;
    }

    .docs-content :global(ul),
    .docs-content :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .docs-content :global(li) {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: var(--color-text-secondary);
      margin-bottom: 0.5rem;
    }

    .docs-content :global(strong) {
      color: var(--color-text);
    }

    .docs-content :global(a) {
      color: #60a5fa;
      text-decoration: none;
    }

    .docs-content :global(a:hover) {
      text-decoration: underline;
    }

    .docs-content :global(hr) {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 2rem 0;
    }

    /* Code blocks */
    .docs-content :global(pre) {
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 1.25rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      line-height: 1.7;
    }

    .docs-content :global(code) {
      font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--color-bg-secondary);
      padding: 0.15em 0.35em;
      border-radius: 0.25rem;
    }

    .docs-content :global(pre code) {
      background: none;
      padding: 0;
      border-radius: 0;
    }

    /* Code block filename header */
    .code-block {
      margin-bottom: 1.5rem;
    }

    .code-block-header {
      display: flex;
      align-items: center;
      padding: 0.5rem 1rem;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-bottom: none;
      border-radius: 0.5rem 0.5rem 0 0;
      font-size: 0.75rem;
      color: var(--color-text-muted);
      font-family: 'Cascadia Code', 'Fira Code', monospace;
    }

    .code-block-header + :global(pre) {
      margin-top: 0;
      border-radius: 0 0 0.5rem 0.5rem;
    }

    /* Feature cards */
    .feature-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .feature-card {
      padding: 1.25rem;
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      background: var(--color-bg-secondary);
    }

    .feature-card h3 {
      margin-top: 0;
      font-size: 1rem;
    }

    .feature-card p {
      font-size: 0.875rem;
      margin-bottom: 0;
    }

    /* Pagination */
    .docs-pagination {
      display: flex;
      justify-content: space-between;
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border);
      max-width: var(--docs-max-width);
    }

    .pagination-link {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      border: 1px solid var(--color-border);
      transition: border-color 0.15s ease, background 0.15s ease;
      max-width: 48%;
    }

    .pagination-link:hover {
      border-color: var(--color-text-muted);
      background: var(--color-bg-secondary);
    }

    .pagination-prev {
      align-items: flex-start;
    }

    .pagination-next {
      align-items: flex-end;
      text-align: right;
      margin-left: auto;
    }

    .pagination-label {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      margin-bottom: 0.25rem;
    }

    .pagination-title {
      font-size: 0.875rem;
      color: var(--color-text);
      font-weight: 500;
    }

    /* Responsive */
    @media (max-width: 1280px) {
      .docs-main {
        max-width: calc(100% - 260px);
        padding: 2rem 1.5rem 4rem;
      }

      .docs-layout {
        max-width: 100%;
      }
    }

    @media (max-width: 1024px) {
      .docs-main {
        max-width: 100%;
        padding: 2rem 1rem 4rem;
      }
    }

    @media (max-width: 640px) {
      .feature-cards {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
