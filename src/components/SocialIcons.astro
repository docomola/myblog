---
/**
 * SocialIcons Component
 * 
 * Displays social media icon links (GitHub, Twitter, Email, RSS)
 * with accessible labels and consistent sizing.
 * 
 * @component
 */
import { siteConfig } from '../config';

interface SocialLink {
  href: string;
  label: string;
  icon: 'github' | 'twitter' | 'linkedin' | 'mastodon' | 'bluesky' | 'email' | 'rss';
  external?: boolean;
}

const links: SocialLink[] = [
  ...(siteConfig.social.github ? [{ href: siteConfig.social.github, label: 'GitHub', icon: 'github' as const, external: true }] : []),
  ...(siteConfig.social.twitter ? [{ href: siteConfig.social.twitter, label: 'Twitter', icon: 'twitter' as const, external: true }] : []),
  ...(siteConfig.social.linkedin ? [{ href: siteConfig.social.linkedin, label: 'LinkedIn', icon: 'linkedin' as const, external: true }] : []),
  ...(siteConfig.social.mastodon ? [{ href: siteConfig.social.mastodon, label: 'Mastodon', icon: 'mastodon' as const, external: true }] : []),
  ...(siteConfig.social.bluesky ? [{ href: siteConfig.social.bluesky, label: 'Bluesky', icon: 'bluesky' as const, external: true }] : []),
  { href: `mailto:${siteConfig.author.email}`, label: 'Email', icon: 'email' as const },
  { href: '/rss.xml', label: 'RSS', icon: 'rss' as const },
];
---

<ul class="social-icons" role="list">
  {links.map(({ href, label, icon, external }) => (
    <li>
      <a href={href} aria-label={label} title={label} class="social-icon" {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
        {icon === 'github' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        )}
        {icon === 'twitter' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        )}
        {icon === 'linkedin' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        )}
        {icon === 'mastodon' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.581.536h.334c1.874 0 3.756-.074 5.607-.394 .047-.008.09-.018.134-.028 2.22-.428 4.347-1.821 4.543-5.365.008-.135.03-.866.03-1.009 0-.308.091-3.082-.044-4.35z"/>
          </svg>
        )}
        {icon === 'bluesky' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
          </svg>
        )}
        {icon === 'email' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        )}
        {icon === 'rss' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93z"/>
          </svg>
        )}
      </a>
    </li>
  ))}
</ul>

<style>
  .social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .social-icon:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    background: var(--color-bg-secondary);
  }

  .social-icon svg {
    width: 1rem;
    height: 1rem;
  }
</style>
