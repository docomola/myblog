---
import { siteConfig } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-bottom">
    <span class="footer-copy">&copy; {currentYear} {siteConfig.author.name}. All rights reserved.</span>
    <div class="footer-social">
      <a href="https://twitter.com/username" target="_blank" rel="noopener noreferrer">X</a>
      <a href="https://linkedin.com/in/username" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://instagram.com/username" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="https://github.com/username" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
    margin-top: auto;
  }

  .footer-bottom {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .footer-social {
    display: flex;
    gap: 1.25rem;
  }

  .footer-social a {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
