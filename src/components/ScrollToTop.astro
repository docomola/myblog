---
/**
 * ScrollToTop Component
 * 
 * Floating button that appears in the bottom-right corner when the user scrolls down
 * past a threshold (300px). Clicking the button smoothly scrolls back to the top of
 * the page. The button fades in/out with a slide animation for a polished UX.
 * 
 * Features:
 * - Auto-shows/hides based on scroll position
 * - Smooth scroll animation
 * - Accessible with keyboard focus and ARIA labels
 * - Works with Astro View Transitions
 * 
 * @component
 * 
 * @example
 * ```astro
 * <ScrollToTop />
 * ```
 */
---

<button 
  class="scroll-to-top" 
  type="button"
  aria-label="Scroll to top"
  title="Scroll to top"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<style>
  .scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: 
      opacity 0.2s ease,
      visibility 0.2s ease,
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
    z-index: 50;
  }

  .scroll-to-top:hover {
    background: var(--color-bg-elevated);
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .scroll-to-top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .scroll-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .scroll-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
  // Guard: only initialize once, even across View Transitions
  if (!document.documentElement.dataset.scrollToTopInit) {
    document.documentElement.dataset.scrollToTopInit = 'true';

    let scrollButton: HTMLElement | null = null;
    let scrollHandler: (() => void) | null = null;
    const SCROLL_THRESHOLD = 300;

    function setupScrollToTop() {
      // Clean up previous listeners if any
      if (scrollButton && scrollHandler) {
        window.removeEventListener('scroll', scrollHandler);
        scrollButton.removeEventListener('click', scrollToTop);
      }

      scrollButton = document.querySelector('.scroll-to-top');
      if (!scrollButton) return;

      scrollHandler = () => {
        if (!scrollButton) return;
        if (window.scrollY > SCROLL_THRESHOLD) {
          scrollButton.classList.add('is-visible');
        } else {
          scrollButton.classList.remove('is-visible');
        }
      };

      function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      window.addEventListener('scroll', scrollHandler, { passive: true });
      scrollButton.addEventListener('click', scrollToTop);

      // Initial check
      scrollHandler();
    }

    // Run on initial load
    setupScrollToTop();

    // Re-run on Astro page transitions (clean up old, set up new)
    document.addEventListener('astro:after-swap', setupScrollToTop);
  }
</script>
