---
/**
 * BaseCard Component
 * 
 * Foundation component providing consistent styling and structure for all card types.
 * This component should not be used directly - instead use specialized cards like
 * ArticleCard, ProjectCard, DecisionCard, or TalkCard for specific content types.
 * 
 * Features:
 * - Consistent hover effects and transitions
 * - Responsive padding and typography
 * - Flexible slot-based content structure
 * - Accessible link wrapper
 * 
 * @component
 * 
 * @slot badge - Optional badge/label at top (e.g., "Featured")
 * @slot meta - Metadata line (date, role, category, etc.)
 * @slot title - Card heading/title
 * @slot description - Card description or summary text
 * @slot tags - Container for tag list
 * @slot default - CTA links or additional content at bottom
 * 
 * @example
 * ```astro
 * <BaseCard href="/example" class="custom-card">
 *   <Fragment slot="meta">January 2024</Fragment>
 *   <Fragment slot="title">Card Title</Fragment>
 *   <Fragment slot="description">Card description text</Fragment>
 *   <ForwardLink text="Read more" />
 * </BaseCard>
 * ```
 */

interface Props {
  /** Target URL for the card link (required) */
  href: string;
  
  /** Additional CSS classes to apply to the card */
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a href={href} class:list={['base-card', className]}>
  <slot name="badge" />
  <span class="card-meta"><slot name="meta" /></span>
  <span class="card-title"><slot name="title" /></span>
  <span class="card-description"><slot name="description" /></span>
  <div style="position:relative;z-index:1"><slot name="tags" /></div>
  <div style="position:relative;z-index:1"><slot /></div>
</a>

<style>
  .base-card {
    display: block;
    position: relative;
    padding: 1.5rem 1.75rem;
    background: rgba(24, 22, 20, 0.75);
    border: 1px solid rgba(255, 248, 235, 0.07);
    border-radius: 1rem;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease, opacity 0.4s ease, box-shadow 0.3s ease;
    opacity: 0.65;
    overflow: hidden;
  }

  .base-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 100% 60% at 50% 100%, rgba(210, 170, 50, 0.22) 0%, rgba(200, 155, 40, 0.08) 40%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    transform-origin: bottom center;
    animation: glowBreathe 5s ease-in-out infinite;
  }

  .base-card:hover {
    border-color: rgba(255, 248, 235, 0.15);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(210, 170, 50, 0.08);
    opacity: 1;
  }

  .card-meta {
    position: relative;
    z-index: 1;
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0.5rem;
  }

  .card-title {
    position: relative;
    z-index: 1;
    display: block;
    font-size: 1.125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 0.625rem;
    line-height: 1.4;
  }

  .card-description {
    position: relative;
    z-index: 1;
    display: block;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  @media (max-width: 640px) {
    .base-card {
      padding: 1.25rem 1.5rem;
    }

    .card-title {
      font-size: 1rem;
    }

    .card-description {
      font-size: 0.875rem;
    }
  }
</style>
